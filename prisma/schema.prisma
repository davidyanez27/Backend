generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}


enum AppRole {
  USER
  ADMIN
}

enum CompanyRole {
  OWNER
  ADMIN
  MEMBER
}

enum CompanyType {
  INDIVIDUAL   
  BUSINESS     
  ENTERPRISE   
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
  INCOMPLETE_EXPIRED
  PAUSED
}

enum BillingPeriod {
  MONTHLY
  YEARLY
  QUARTERLY
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELED
  REFUNDED
  PARTIALLY_REFUNDED
  COMPLETED
}

enum PaymentMethod {
  CARD
  BANK_TRANSFER
  PAYPAL
  OTHER
}


enum InvoicePaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  OTHER
}

enum RefundReason {
  DUPLICATE
  FRAUDULENT
  REQUESTED_BY_CUSTOMER
  OTHER
}

enum RefundStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELED
}


enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELED
}

enum ItemType {
  PRODUCT
  SERVICE
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
  CANCELED
}

enum WorkOrderStatus {
  DRAFT
  APPROVED
  STARTED
  COMPLETED
  CANCELED
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  RECEIVED
  CANCELED
}




model User {
  id              Int             @id @default(autoincrement())
  uuid            String          @unique @default(uuid())
  email           String          @unique
  emailValidated  Boolean         @default(false)
  password        String?
  fullName        String
  appRole         AppRole         @default(USER)
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  //Relations
  memberships        CompanyMember[]
  createdRoles       Role[]              @relation("RoleCreatedBy")
  updatedRoles       Role[]              @relation("RoleUpdatedBy")
  createdCustomers   Customer[]          @relation("CustomerCreatedBy")
  updatedCustomers   Customer[]          @relation("CustomerUpdatedBy")
  createdItems       Item[]              @relation("ItemCreatedBy")
  updatedItems       Item[]              @relation("ItemUpdatedBy")
  createdInvoices    Invoice[]           @relation("InvoiceCreatedBy")
  updatedInvoices    Invoice[]           @relation("InvoiceUpdatedBy")
  createdPayments    SubscriptionPayment[] @relation("PaymentCreatedBy")
  createdProjects    Project[]           @relation("ProjectCreatedBy")
  updatedProjects    Project[]           @relation("ProjectUpdatedBy")
  createdPOs         PurchaseOrder[]     @relation("POCreatedBy")
  updatedPOs         PurchaseOrder[]     @relation("POUpdatedBy")
  stockAdjustments   StockAdjustment[]   @relation("StockAdjustmentCreatedBy")
  auditLogs          AuditLog[]          @relation("UserAuditLogs")
  attachments        Attachment[]        @relation("UserAttachments")

  @@map("users")
}




model Permission {
  id Int @id @default(autoincrement())
  key         String  @unique
  description String?
  rolePermissions RolePermission[]

  @@map("permissions")
}

model Role {
  id   Int    @id @default(autoincrement())
  uuid String @db.Uuid @unique @default(uuid())

  name        String
  isSystem    Boolean          @default(false) 
  companyId   Int              
  createdById Int?  @map("createdBy")       
  createdAt   DateTime         @default(now()) 
  updatedAt   DateTime         @updatedAt 
  permissions RolePermission[]
  members     CompanyMember[]

  updatedById Int?  @map("updatedBy")

  //Relations
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("RoleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?   @relation("RoleUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([companyId, name])
  @@index([companyId])
  @@map("roles")
}

model RolePermission {
  roleId       Int 
  permissionId Int 

  //Relations
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}




model Company {
  id                Int             @id @default(autoincrement())
  uuid              String          @unique @default(uuid())
  name              String          // No @unique - allow duplicate names
  companyType       CompanyType     @default(INDIVIDUAL)
  
  // Company details with defaults for incomplete profiles
  idType            String          @default("PENDING") @map("id_type")
  idValue           String          @default("PENDING") @map("id_value")
  email             String
  phone             String          @default("PENDING")
  address           String          @default("PENDING")
  
  // Set during registration based on user location
  country           String          // ISO 3166-1 alpha-2 (e.g., "US", "HN")
  currency          String          // ISO 4217 (e.g., "USD", "HNL")
  
  // Branding
  logo              String?         @db.Text   // base64 data URI (MVP), swap to S3 URL later

  // Stripe integration
  stripeCustomerId  String?         @unique @map("stripe_customer_id")
  
  // Status
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  members      CompanyMember[]
  roles        Role[]
  subscription Subscription?

  customers Customer[]
  items     Item[]
  stocks    StockItem[]

  invoices   Invoice[]
  subscriptionPayments SubscriptionPayment[]
  workOrders WorkOrder[]

  projects       Project[]
  suppliers      Supplier[]
  purchaseOrders PurchaseOrder[]
  usageRecords    UsageRecord[]
  usageCounters   CompanyUsageCounter[]
  invoiceSequence InvoiceSequence?
  taxRates       TaxRate[]
  auditLogs      AuditLog[]
  attachments    Attachment[]
  @@map("companies")
}

model CompanyMember {
  id           Int          @id @default(autoincrement())
  uuid         String       @unique @default(uuid())
  companyRole  CompanyRole  @default(MEMBER)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Foreign Keys
  companyId    Int
  userId       Int
  roleId       Int?

  // Relations
  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role?        @relation(fields: [roleId], references: [id], onDelete: SetNull)

  // Opposite relations
  assignedTasks  Task[]      @relation("TaskAssignee")
  approvedWOs    WorkOrder[] @relation("WorkOrderApprover")

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([userId])
  @@index([roleId])
  @@map("company_members")
}

// ============================================
// Plan
// ============================================

model Plan {
  id   Int    @id @default(autoincrement())
  key  String @unique // "FREE", "PREMIUM"
  name String

  maxUsers Int @default(3) @map("max_users")

  provider String? @map("provider")
  priceId  String? @map("price_id")

  features              PlanFeature[]
  subscriptions         Subscription[]
  subscriptionFeatures  SubscriptionFeature[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("plans")
}

model Feature {
  id   Int    @id @default(autoincrement())
  key  String @unique // "BILLING", "INVENTORY", "PROJECTS", "CUSTOM_ROLES"
  name String

  plans PlanFeature[]

  @@map("features")
}

model PlanFeature {
  planId    Int
  featureId Int

  plan    Plan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  feature Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@id([planId, featureId])
  @@map("plan_features")
}

model Customer {
  id   Int    @id @default(autoincrement())
  uuid String @db.Uuid @unique @default(uuid())

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId Int     @map("company_id")

  name            String
  email           String?
  phone           String
  billingAddress  String @map("billing_address")
  shippingAddress String @map("shipping_address")
  notes           String?
  type            String   @map("type_identifier")
  identifier      String   @map("identifier")

  createdBy   User? @relation("CustomerCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdById Int?  @map("createdBy")

  updatedBy   User? @relation("CustomerUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  updatedById Int?  @map("updatedBy")

  invoices       Invoice[]
  projects       Project[]
  customerPrices CustomerItemPrice[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  isActive  Boolean  @default(true) @map("is_active")

  @@unique([companyId, email])
  @@index([companyId])
  @@index([companyId, isActive])
  @@index([companyId, type])
  @@index([email])
  @@map("customers")
}


model Item {
  id   Int    @id @default(autoincrement())
  uuid String @db.Uuid @unique @default(uuid())

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId Int     @map("company_id")

  name        String
  description String
  type        ItemType @default(PRODUCT)

  unit         String  @default("unit")
  defaultPrice Decimal @map("default_price") @db.Decimal(12, 2)
  currency     String  @default("USD")

  trackInventory Boolean @default(false) @map("track_inventory")

  createdBy   User? @relation("ItemCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdById Int?  @map("createdBy")

  updatedBy   User? @relation("ItemUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  updatedById Int?  @map("updatedBy")

  invoiceItems   InvoiceItem[]
  projectLines   ProjectLineItem[]
  purchaseItems  PurchaseOrderItem[]
  customerPrices CustomerItemPrice[]
  stock StockItem?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  isActive  Boolean  @default(true) @map("is_active")

  @@unique([companyId, name, type])
  @@index([companyId, type])
  @@index([companyId, trackInventory])
  @@map("items")
}

model CustomerItemPrice {
  id   Int    @id @default(autoincrement())
  uuid String @db.Uuid @unique @default(uuid())

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId Int      @map("customer_id")

  item   Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId Int  @map("item_id")

  customPrice Decimal? @map("custom_price") @db.Decimal(12, 2)
  currency    String?
  notes       String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([customerId, itemId])
  @@index([customerId])
  @@index([itemId])
  @@map("customer_item_prices")
}

model StockItem {
  id   Int    @id @default(autoincrement())
  uuid String @db.Uuid @unique @default(uuid())

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId Int     @map("company_id")

  item   Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId Int  @unique @map("item_id")

  quantity Decimal @default(0) @db.Decimal(18, 3)

  adjustments StockAdjustment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([companyId])
  @@map("stock_items")
}

model StockAdjustment {
  id   Int    @id @default(autoincrement())
  uuid String @db.Uuid @unique @default(uuid())

  stockItem   StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  stockItemId Int       @map("stock_item_id")

  delta     Decimal @db.Decimal(18, 3)
  reason    String?
  reference String?

  createdBy   User? @relation("StockAdjustmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdById Int?  @map("createdBy")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([stockItemId])
  @@map("stock_adjustments")
}

model Project {
  id   Int    @id @default(autoincrement())
  uuid String @db.Uuid @unique @default(uuid())

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId Int     @map("company_id")

  name        String
  description String?
  status      ProjectStatus @default(DRAFT)

  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerId Int?      @map("customer_id")

  createdBy   User? @relation("ProjectCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdById Int?  @map("createdBy")

  updatedBy   User? @relation("ProjectUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  updatedById Int?  @map("updatedBy")

  tasks      Task[]
  workOrders WorkOrder[]
  billables          ProjectLineItem[]
  invoices           Invoice[]

  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  isActive  Boolean  @default(true) @map("is_active")

  @@index([companyId])
  @@index([customerId])
  @@map("projects")
}

model Task {
  id   Int    @id @default(autoincrement())
  uuid String @db.Uuid @unique @default(uuid())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId Int     @map("project_id")

  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Int?

  assignedTo         CompanyMember? @relation("TaskAssignee", fields: [assignedToMemberId], references: [id], onDelete: SetNull)
  assignedToMemberId Int?           @map("assigned_to_member_id")

  dueDate DateTime? @map("due_date")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([projectId])
  @@index([assignedToMemberId])
  @@map("tasks")
}

model WorkOrder {
  id   Int    @id @default(autoincrement())
  uuid String @db.Uuid @unique @default(uuid())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId Int     @map("project_id")

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId Int     @map("company_id")

  status WorkOrderStatus @default(DRAFT)
  notes  String?

  approvedBy         CompanyMember? @relation("WorkOrderApprover", fields: [approvedByMemberId], references: [id], onDelete: SetNull)
  approvedByMemberId Int?           @map("approved_by_member_id")

  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([companyId])
  @@index([projectId])
  @@map("work_orders")
}

model ProjectLineItem {
  id   Int    @id @default(autoincrement())
  uuid String @db.Uuid @unique @default(uuid())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId Int     @map("project_id")

  item   Item? @relation(fields: [itemId], references: [id], onDelete: SetNull)
  itemId Int?  @map("item_id")

  description String
  quantity    Decimal @default(1) @db.Decimal(12, 3)
  unitPrice   Decimal @map("unit_price") @db.Decimal(12, 2)
  currency    String  @default("USD")
  lineTotal   Decimal @map("line_total") @db.Decimal(12, 2)

  isBillable Boolean @default(true) @map("is_billable")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([projectId])
  @@index([itemId])
  @@map("project_line_items")
}

model Supplier {
  id   Int    @id @default(autoincrement())
  uuid String @db.Uuid @unique @default(uuid())

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId Int     @map("company_id")

  name    String
  email   String?
  phone   String?
  address String?
  notes   String?

  purchaseOrders PurchaseOrder[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  isActive  Boolean  @default(true) @map("is_active")

  @@unique([companyId, name])
  @@index([companyId])
  @@map("suppliers")
}

model PurchaseOrder {
  id   Int    @id @default(autoincrement())
  uuid String @db.Uuid @unique @default(uuid())

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId Int     @map("company_id")

  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  supplierId Int?      @map("supplier_id")

  number   String
  status   PurchaseOrderStatus @default(DRAFT)
  currency String              @default("USD")

  notes String?

  orderedAt  DateTime? @map("ordered_at")
  receivedAt DateTime? @map("received_at")

  createdBy   User? @relation("POCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdById Int?  @map("createdBy")

  updatedBy   User? @relation("POUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  updatedById Int?  @map("updatedBy")

  items PurchaseOrderItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([companyId, number])
  @@index([companyId])
  @@index([supplierId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id Int @id @default(autoincrement())

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  purchaseOrderId Int           @map("purchase_order_id")

  item   Item @relation(fields: [itemId], references: [id], onDelete: Restrict)
  itemId Int  @map("item_id")

  quantity  Decimal @db.Decimal(12, 3)
  unitCost  Decimal @map("unit_cost") @db.Decimal(12, 2)
  lineTotal Decimal @map("line_total") @db.Decimal(12, 2)

  @@index([purchaseOrderId])
  @@index([itemId])
  @@map("purchase_order_items")
}

// ============================================
//          Invoice
//   ============================================ 

model InvoiceSequence {
  id        Int @id @default(autoincrement())
  companyId Int @unique @map("company_id")
  current   Int @default(1)
  prefix    String @default("INV")
  suffix    String @default("")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("invoice_sequences")
}

enum InvoiceTerms {
  NET_15
  NET_30
  NET_45
  NET_60
  DUE_ON_RECEIPT
  CUSTOM
}

model TaxRate {
  id        Int @id @default(autoincrement())
  companyId Int @map("company_id")
  name      String
  rate      Decimal @db.Decimal(5, 4) // e.g., 0.0825 for 8.25%
  isDefault Boolean @default(false) @map("is_default")
  isActive  Boolean @default(true) @map("is_active")

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([companyId, name])
  @@index([companyId, isDefault])
  @@map("tax_rates")
}

model Invoice {
  id   Int    @id @default(autoincrement())
  uuid String @db.Uuid @unique @default(uuid())

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId Int     @map("company_id")

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  customerId Int      @map("customer_id")

  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId Int?     @map("project_id")

  number   String
  status   InvoiceStatus @default(DRAFT)
  currency String        @default("USD")

  issueDate DateTime  @map("issue_date")
  dueDate   DateTime? @map("due_date")

  subtotal Decimal @db.Decimal(12, 2)
  tax      Decimal @default(0) @db.Decimal(12, 2)
  discount Decimal @default(0) @db.Decimal(12, 2)
  total    Decimal @db.Decimal(12, 2)

  // Tax and payment terms
  taxRateId      Int?           @map("tax_rate_id")
  taxRate        TaxRate?       @relation(fields: [taxRateId], references: [id], onDelete: SetNull)
  paymentTerms   InvoiceTerms   @default(NET_30) @map("payment_terms")
  customTerms    String?        @map("custom_terms")

  // Simple payment tracking
  amountPaid     Decimal   @default(0) @db.Decimal(12, 2) @map("amount_paid")
  paymentMethod  InvoicePaymentMethod   @map("invoice_payment_method")
  paymentDate    DateTime? @map("payment_date")
  paymentNotes   String?   @map("payment_notes")

  notes  String?
  pdfUrl String? @map("pdf_url")

  createdBy   User? @relation("InvoiceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdById Int?  @map("createdBy")

  updatedBy   User? @relation("InvoiceUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  updatedById Int?  @map("updatedBy")

  items InvoiceItem[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, number])
  @@index([companyId])
  @@index([customerId])
  @@index([projectId])
  @@index([status, dueDate])
  @@index([companyId, status, issueDate])
  @@index([customerId, status])
  @@index([amountPaid])
  @@map("invoices")
}

model InvoiceItem {
  id   Int    @id @default(autoincrement())
  uuid String @db.Uuid @unique @default(uuid())

  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId Int     @map("invoice_id")

  item   Item? @relation(fields: [itemId], references: [id], onDelete: SetNull)
  itemId Int?  @map("item_id")

  description String
  quantity    Decimal @default(1) @db.Decimal(12, 3)
  unitPrice   Decimal @map("unit_price") @db.Decimal(12, 2)
  discount    Decimal @default(0) @db.Decimal(12, 2)
  lineTotal   Decimal @map("line_total") @db.Decimal(12, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([invoiceId])
  @@index([itemId])
  @@map("invoice_items")
}






model Subscription {
  id                    Int                @id @default(autoincrement())
  uuid                  String             @unique @default(uuid())
  
  // Stripe IDs
  stripeSubscriptionId  String             @unique @map("stripe_subscription_id")
  stripePriceId         String             @map("stripe_price_id")
  stripeProductId       String?            @map("stripe_product_id")
  
  // Subscription details
  status                SubscriptionStatus @default(TRIAL)
  planName              String             // "Starter", "Pro", "Enterprise"
  billingPeriod         BillingPeriod      @default(MONTHLY)
  
  // Pricing
  amount                Decimal            @db.Decimal(10, 2)
  currency              String
  
  // Dates
  currentPeriodStart    DateTime           @map("current_period_start")
  currentPeriodEnd      DateTime           @map("current_period_end")
  cancelAt              DateTime?          @map("cancel_at")
  canceledAt            DateTime?          @map("canceled_at")
  trialStart            DateTime?          @map("trial_start")
  trialEnd              DateTime?          @map("trial_end")
  
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  
  // Foreign Keys
  companyId             Int                @unique
  planId                Int?

  // Relations
  company               Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan                  Plan?              @relation(fields: [planId], references: [id], onDelete: SetNull)
  subscriptionPayments  SubscriptionPayment[]

  @@index([companyId])
  @@index([status])
  @@map("subscriptions")
}

model SubscriptionPayment {
  id                      Int            @id @default(autoincrement())
  uuid                    String         @unique @default(uuid())

  // Stripe IDs
  stripePaymentIntentId   String?        @unique @map("stripe_payment_intent_id")
  stripeChargeId          String?        @unique @map("stripe_charge_id")
  stripeInvoiceId         String?        @map("stripe_invoice_id")

  // Payment details
  amount                  Decimal        @db.Decimal(10, 2)
  currency                String
  status                  PaymentStatus  @default(PENDING)
  paymentMethod           PaymentMethod  @map("payment_method")

  // Metadata
  description             String?
  receiptUrl              String?        @map("receipt_url")
  failureReason           String?        @map("failure_reason")

  // Timestamps
  paidAt                  DateTime?      @map("paid_at")
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  // Foreign Keys
  companyId               Int
  subscriptionId          Int?
  createdById             Int?           @map("created_by")

  // Relations
  company                 Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subscription            Subscription?  @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  createdBy               User?          @relation("PaymentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  refunds                 Refund[]

  @@index([companyId])
  @@index([subscriptionId])
  @@index([status])
  @@index([stripePaymentIntentId])
  @@map("subscription_payments")
}

model Refund {
  id                Int           @id @default(autoincrement())
  uuid              String        @unique @default(uuid())
  
  // Stripe ID
  stripeRefundId    String        @unique @map("stripe_refund_id")
  
  // Refund details
  amount            Decimal       @db.Decimal(10, 2)
  currency          String
  reason            RefundReason?
  status            RefundStatus  @default(PENDING)
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  
  // Foreign Keys
  paymentId         Int
  
  // Relations
  payment           SubscriptionPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  
  @@index([paymentId])
  @@map("refunds")
}

model StripeWebhookEvent {
  id              Int       @id @default(autoincrement())
  
  stripeEventId   String    @unique @map("stripe_event_id")
  eventType       String    @map("event_type")
  
  // Store the full event payload
  payload         Json
  
  // Processing status
  processed       Boolean   @default(false)
  processedAt     DateTime? @map("processed_at")
  error           String?
  
  createdAt       DateTime  @default(now())
  
  @@index([eventType])
  @@index([processed])
  @@map("stripe_webhook_events")
}

// ============================================
// SUBSCRIPTION FEATURES & LIMITS
// ============================================ 

model SubscriptionFeature {
  id              Int     @id @default(autoincrement())

  planId          Int     @map("plan_id")
  featureName     String  // "invoices_per_month", "team_members", "api_access"
  limit           Int?    // NULL = unlimited
  enabled         Boolean @default(true)

  plan            Plan    @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, featureName])
  @@index([planId])
  @@map("subscription_features")
}

// Tracks current usage per company per feature.
// Periodic features (invoices_per_month) get a new row each billing period.
// Absolute features (team_members, projects) use a single row (periodStart = subscription start).
model CompanyUsageCounter {
  id          Int      @id @default(autoincrement())
  companyId   Int      @map("company_id")
  featureName String   @map("feature_name")  // matches SubscriptionFeature.featureName
  current     Int      @default(0)
  periodStart DateTime @map("period_start")   // billing period start or subscription start

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, featureName, periodStart])
  @@index([companyId])
  @@index([companyId, featureName])
  @@map("company_usage_counters")
}






model UsageRecord {
  id              Int       @id @default(autoincrement())
  uuid            String    @unique @default(uuid())
  
  metricName      String    // "invoices_sent", "api_calls", "storage_gb"
  quantity        Int
  timestamp       DateTime  @default(now())
  
  // Foreign Keys
  companyId       Int
  
  // Relations
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  @@index([companyId, metricName])
  @@index([timestamp])
  @@index([companyId, timestamp])
  @@index([metricName, timestamp])
  @@map("usage_records")
}

// ============================================
//            AUDIT LOGGING
// ============================================

model AuditLog {
  id        Int @id @default(autoincrement())
  companyId Int @map("company_id")
  userId    Int? @map("user_id")

  entityType String @map("entity_type") // "invoice", "customer", "project", etc.
  entityId   Int    @map("entity_id")
  action     String // "created", "updated", "deleted", "status_changed"
  oldData    Json?  @map("old_data")
  newData    Json?  @map("new_data")

  timestamp DateTime @default(now())
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation("UserAuditLogs", fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, entityType, timestamp])
  @@index([entityType, entityId])
  @@index([userId, timestamp])
  @@map("audit_logs")
}


model Attachment {
  id         Int @id @default(autoincrement())
  uuid       String @unique @default(uuid())
  companyId  Int    @map("company_id")

  filename     String @map("filename")
  originalName String @map("original_name")
  mimeType     String @map("mime_type")
  fileSize     Int    @map("file_size")
  url          String

  // Polymorphic relations
  entityType String @map("entity_type") // "invoice", "customer", "project", "task"
  entityId   Int    @map("entity_id")

  uploadedBy   User? @relation("UserAttachments", fields: [uploadedById], references: [id], onDelete: SetNull)
  uploadedById Int?  @map("uploaded_by_id")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([companyId])
  @@index([entityType, entityId])
  @@index([uploadedById])
  @@map("attachments")
}


